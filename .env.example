# X API
# For public lists, an app Bearer Token may be enough.
# For private lists, use either a user-context OAuth2 access token as X_BEARER_TOKEN,
# or set X_AUTH_MODE=oauth1 and fill the OAuth 1.0a keys below.
X_AUTH_MODE=bearer
X_BEARER_TOKEN=replace_me
X_API_KEY=
X_API_KEY_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_LIST_ID=1234567890
X_API_BASE=https://api.x.com/2
X_MAX_RESULTS=50
X_MAX_PAGES=1

# LLM: OpenAI-compatible Chat Completions endpoint
LLM_API_KEY=replace_me
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=60
LLM_MIN_IMPORTANCE=3

# Telegram
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_CHAT_ID=replace_me

# Runtime
POLL_INTERVAL_SECONDS=300
STATE_PATH=data/state.json
LOG_LEVEL=INFO
